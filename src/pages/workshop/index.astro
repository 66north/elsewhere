---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { path } from '../../lib/site';

// Get all guides
const guides = await getCollection('guides');

// Group by category and compute stats
const byCategory = new Map<string, any[]>();
guides.forEach((guide) => {
  const cat = guide.data.category || 'other';
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(guide);
});

// Build category stats
const categories = Array.from(byCategory.entries())
  .map(([name, guides]) => {
    const times = guides
      .map((g) => g.data.time_minutes)
      .filter((t) => t !== undefined && t > 0);
    const minTime = times.length ? Math.min(...times) : 0;
    const maxTime = times.length ? Math.max(...times) : 0;

    const diffCounts = { easy: 0, moderate: 0, hard: 0 };
    guides.forEach((g) => {
      const d = g.data.difficulty || 'moderate';
      if (d in diffCounts) diffCounts[d as keyof typeof diffCounts]++;
    });

    // Pick 2 featured guides from this category
    const featured = guides.slice(0, 2);

    return {
      name,
      count: guides.length,
      timeRange: minTime === maxTime ? `${minTime}m` : `${minTime}–${maxTime}m`,
      diffCounts,
      guides,
      featured,
    };
  })
  .sort((a, b) => b.count - a.count);

const totalGuides = guides.length;
const avgTime = Math.round(
  guides.reduce((sum, g) => sum + (g.data.time_minutes || 0), 0) / guides.length
);

// Fault code guides for the lookup box
const codeGuides = guides
  .filter((g) => g.data.category === 'codes' && /^fault-code-p/.test(g.data.slug))
  .map((g) => ({ slug: g.data.slug, code: g.data.slug.replace('fault-code-', '').toUpperCase(), title: g.data.title }))
  .sort((a, b) => a.code.localeCompare(b.code));

// Symptom buckets: map top-level symptoms to guide slugs
const symptomBuckets = [
  {
    icon: '🔊',
    label: 'Noise',
    hint: 'Squealing, grinding, knocking, clunking',
    slugs: ['brake-pads-front', 'brake-noise-and-feel', 'suspension-squeaks-and-clunks', 'cv-joint-driveshaft', 'rear-axle-bearing-inspection'],
  },
  {
    icon: '💡',
    label: 'Warning light',
    hint: 'Dashboard lights, MIL, DPF, 4WD',
    slugs: ['dashboard-warning-lights', 'dpf-warning-light', 'fault-code-p0400', 'fault-code-p2002', 'fault-code-p0700'],
  },
  {
    icon: '🔑',
    label: "Won't start",
    hint: "No crank, slow crank, starts then dies",
    slugs: ['engine-wont-start', 'starting-charging-problems', 'battery-replacement', 'glow-plugs', '4m40-glow-plugs'],
  },
  {
    icon: '💧',
    label: 'Leaking',
    hint: 'Oil, coolant, transmission fluid',
    slugs: ['engine-oil-specifications', 'coolant-flush', 'radiator-hose-replacement', 'v5awf-atf-check', 'power-steering-problems'],
  },
  {
    icon: '📳',
    label: 'Vibration / rough',
    hint: 'Rough idle, misfire, shaking',
    slugs: ['rough-idle', 'fault-code-p0300', 'cv-joint-driveshaft', 'tire-pressure-and-wear', 'suspension-squeaks-and-clunks'],
  },
  {
    icon: '🚗',
    label: '4WD issue',
    hint: "Won't engage, stuck, indicator flashing",
    slugs: ['4wd-not-engaging', 'rear-differential-lock-system', 'transmission-fluid', 'manual-transmission-problems'],
  },
];

// Build title map for symptom guide slugs
const titleMap = new Map(guides.map((g) => [g.data.slug, g.data.title]));

// Breadcrumb schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://66north.github.io/elsewhere',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Workshop',
      item: 'https://66north.github.io/elsewhere/workshop',
    },
  ],
};

// CollectionPage schema
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Workshop – Repair Guides',
  description: 'Comprehensive repair guides for Mitsubishi Pajero covering maintenance, troubleshooting, and modifications.',
  mainEntity: {
    '@type': 'Collection',
    name: 'Pajero Repair Guides',
    hasPart: guides.slice(0, 10).map(g => ({
      '@type': 'HowTo',
      name: g.data.title,
      description: g.data.description || '',
      url: `https://66north.github.io/elsewhere/workshop/guides/${g.data.slug}`,
    })),
  },
};
---

<BaseLayout section="workshop" title="Workshop" description="Repair guides, fault codes, parts, and the factory service manual archive.">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  <div class="workshop-hub">
    <!-- Hero section -->
    <section class="hero">
      <div class="hero-inner">
        <span class="eyebrow">Workshop · 66°N</span>
        <h1>Fix it yourself (or at least try)</h1>
        <p class="lede">
          I've gathered information and guides covering maintenance, troubleshooting, parts, specifications, and diagnostic codes for all Pajero/Montero/Shogun generations.
        </p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">{totalGuides}</span>
            <span class="stat-label">Guides</span>
          </div>
          <div class="stat">
            <span class="stat-value">{avgTime}m</span>
            <span class="stat-label">Avg time</span>
          </div>
          <div class="stat">
            <span class="stat-value">{categories.length}</span>
            <span class="stat-label">Categories</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick-access banners -->
    <section class="quick-banners">
      <div class="banner-row">
        <div class="quick-banner">
          <div>
            <span class="buying-label">What's due on your car?</span>
            <p class="buying-desc">Enter your mileage to see which service items are overdue or coming up.</p>
          </div>
          <a href={path('/workshop/maintenance')} class="buying-link">Maintenance tracker →</a>
        </div>
        <div class="quick-banner">
          <div>
            <span class="buying-label">Looking to buy a Pajero?</span>
            <p class="buying-desc">Pre-purchase inspection checklist, known weak points, and what to budget.</p>
          </div>
          <a href={path('/workshop/buying')} class="buying-link">Buyer's guide →</a>
        </div>
      </div>
    </section>

    <!-- What's wrong? — symptom-first entry -->
    <section class="symptom-section">
      <h2 class="section-title">What's wrong?</h2>
      <p class="section-intro">Not sure what to search for? Start here — pick the symptom that fits best.</p>
      <div class="symptom-grid">
        {symptomBuckets.map((bucket) => (
          <div class="symptom-card">
            <div class="symptom-header">
              <span class="symptom-icon">{bucket.icon}</span>
              <div>
                <span class="symptom-label">{bucket.label}</span>
                <span class="symptom-hint">{bucket.hint}</span>
              </div>
            </div>
            <ul class="symptom-guides">
              {bucket.slugs.slice(0, 4).map((slug) => titleMap.has(slug) && (
                <li>
                  <a href={path(`/workshop/guides/${slug}`)} class="symptom-guide-link">
                    {titleMap.get(slug)}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Fault code lookup -->
    <section class="code-lookup-section">
      <h2 class="section-title">Fault code lookup</h2>
      <p class="section-intro">Got a warning light? Enter your P-code to jump straight to the diagnosis guide.</p>
      <div class="code-lookup">
        <div class="code-input-wrap">
          <input
            type="text"
            id="code-input"
            class="code-input"
            placeholder="e.g. P0400"
            maxlength="6"
            autocomplete="off"
            spellcheck="false"
          />
          <button class="code-go-btn" id="code-go" type="button">Go</button>
        </div>
        <div class="code-quick-list">
          {codeGuides.slice(0, 8).map((g) => (
            <a href={path(`/workshop/guides/${g.slug}`)} class="code-chip" data-code={g.code}>
              {g.code}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Category grid -->
    <section class="categories-section">
      <h2 class="section-title">Browse by category</h2>
      <div class="categories-grid">
        {categories.map((cat) => (
          <a href={path(`/workshop/guides#cat-${cat.name}`)} class="category-card">
            <div class="category-header">
              <h3>{cat.name}</h3>
              <span class="guide-count">{cat.count}</span>
            </div>

            <div class="category-time">
              <span class="time-label">Typical time:</span>
              <span class="time-value">{cat.timeRange}</span>
            </div>

            <div class="difficulty-breakdown">
              {cat.diffCounts.easy > 0 && (
                <span class="diff-pill diff-easy">
                  <span class="diff-label">Easy</span>
                  <span class="diff-count">{cat.diffCounts.easy}</span>
                </span>
              )}
              {cat.diffCounts.moderate > 0 && (
                <span class="diff-pill diff-moderate">
                  <span class="diff-label">Moderate</span>
                  <span class="diff-count">{cat.diffCounts.moderate}</span>
                </span>
              )}
              {cat.diffCounts.hard > 0 && (
                <span class="diff-pill diff-hard">
                  <span class="diff-label">Hard</span>
                  <span class="diff-count">{cat.diffCounts.hard}</span>
                </span>
              )}
            </div>

            <div class="card-footer">
              <span class="view-link">View guides</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Generation quick filter -->
    <section class="filters-section">
      <h2 class="section-title">Filter by generation</h2>
      <div class="filter-chips">
        <a href={path('/workshop/guides')} class="chip chip-active">All guides</a>
        <a href={path('/workshop/guides?gen=Gen+2')} class="chip">Gen 2 (1990–1999)</a>
        <a href={path('/workshop/guides?gen=Gen+3')} class="chip">Gen 3 (1999–2006)</a>
        <a href={path('/workshop/guides?gen=Gen+4')} class="chip">Gen 4 (2006–2015)</a>
      </div>
    </section>
  </div>

  <style>
    .workshop-hub {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 var(--spacing-page);
    }

    .hero {
      padding: 80px 0 60px;
      border-bottom: 1px solid var(--border);
    }

    .hero-inner { }

    .hero h1 {
      font-size: 40px;
      margin: 12px 0 24px;
      color: var(--fg);
    }

    .lede {
      font-size: 17px;
      line-height: 1.6;
      color: var(--fg-muted);
      max-width: 60ch;
      margin-bottom: 32px;
    }

    .hero-stats {
      display: flex;
      gap: 40px;
    }

    .stat {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .stat-value {
      font-size: 28px;
      font-weight: 700;
      color: var(--fg);
    }

    .stat-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--fg-muted);
      font-weight: 500;
    }

    .categories-section {
      padding: 60px 0;
    }

    .section-title {
      font-size: 18px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--fg-soft);
      margin-bottom: 24px;
    }

    .categories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
      margin-bottom: 40px;
    }

    .category-card {
      display: flex;
      flex-direction: column;
      gap: 16px;
      padding: 20px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--bg-elev);
      color: inherit;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }

    .category-card:hover {
      background: var(--bg-sunken);
      border-color: var(--border-strong);
    }

    .category-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .category-header h3 {
      margin: 0;
      font-size: 16px;
      font-weight: 600;
      color: var(--fg);
      flex: 1;
    }

    .guide-count {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 4px;
      background: var(--bg-sunken);
      border: 1px solid var(--border);
      font-size: 12px;
      font-weight: 600;
      color: var(--fg-muted);
      flex-shrink: 0;
    }

    .category-time {
      display: flex;
      align-items: baseline;
      gap: 6px;
      font-size: 13px;
    }

    .time-label {
      color: var(--fg-muted);
    }

    .time-value {
      color: var(--fg);
      font-weight: 600;
      font-family: 'Geist Mono', monospace;
    }

    .difficulty-breakdown {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .diff-pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 8px;
      border-radius: 3px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .diff-easy {
      background: oklch(0.85 0.12 150);
      color: oklch(0.35 0.1 150);
    }

    .diff-moderate {
      background: oklch(0.82 0.12 70);
      color: oklch(0.4 0.1 70);
    }

    .diff-hard {
      background: oklch(0.8 0.12 10);
      color: oklch(0.35 0.1 10);
    }

    .diff-label {
      opacity: 0.7;
    }

    .diff-count {
      font-weight: 700;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 8px;
      border-top: 1px solid var(--border);
      font-size: 13px;
      color: var(--fg-muted);
    }

    .view-link {
      font-weight: 500;
      color: var(--fg);
    }

    .arrow {
      opacity: 0.5;
      transition: opacity 0.15s;
    }

    .category-card:hover .arrow {
      opacity: 1;
    }

    .filters-section {
      padding: 40px 0;
      border-top: 1px solid var(--border);
    }

    .filter-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chip {
      padding: 8px 14px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--bg-elev);
      color: var(--fg-muted);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }

    .chip:hover {
      background: var(--bg-sunken);
      border-color: var(--border-strong);
      color: var(--fg);
    }

    .chip-active {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }

    .chip-active:hover {
      background: var(--accent);
      border-color: var(--accent);
    }

    /* ── Quick banners ── */
    .quick-banners {
      padding: 24px 0;
      border-top: 1px solid var(--border);
    }

    .banner-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .quick-banner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      padding: 20px 24px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--bg-elev);
    }

    @media (max-width: 640px) {
      .banner-row { grid-template-columns: 1fr; }
    }

    .buying-label {
      display: block;
      font-size: 14px;
      font-weight: 700;
      color: var(--fg);
      margin-bottom: 4px;
    }

    .buying-desc {
      font-size: 13px;
      color: var(--fg-muted);
      margin: 0;
    }

    .buying-link {
      display: inline-block;
      padding: 8px 16px;
      border: 1px solid var(--accent);
      border-radius: var(--radius-sm);
      color: var(--accent);
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      white-space: nowrap;
      transition: background 0.12s, color 0.12s;
    }

    .buying-link:hover {
      background: var(--accent);
      color: white;
    }

    /* ── Symptom section ── */
    .symptom-section {
      padding: 60px 0;
      border-top: 1px solid var(--border);
    }

    .section-intro {
      font-size: 15px;
      color: var(--fg-muted);
      margin-bottom: 24px;
      margin-top: -8px;
    }

    .symptom-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }

    .symptom-card {
      padding: 20px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--bg-elev);
    }

    .symptom-header {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 16px;
    }

    .symptom-icon {
      font-size: 22px;
      line-height: 1;
      flex-shrink: 0;
    }

    .symptom-label {
      display: block;
      font-size: 15px;
      font-weight: 600;
      color: var(--fg);
      margin-bottom: 2px;
    }

    .symptom-hint {
      display: block;
      font-size: 12px;
      color: var(--fg-muted);
    }

    .symptom-guides {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .symptom-guide-link {
      display: block;
      font-size: 13px;
      color: var(--fg-soft);
      text-decoration: none;
      padding: 4px 0;
      border-bottom: 1px dashed var(--border);
      transition: color 0.12s;
    }

    .symptom-guide-link:last-child {
      border-bottom: none;
    }

    .symptom-guide-link:hover {
      color: var(--accent);
    }

    /* ── Code lookup section ── */
    .code-lookup-section {
      padding: 60px 0;
      border-top: 1px solid var(--border);
    }

    .code-lookup {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .code-input-wrap {
      display: flex;
      gap: 8px;
      max-width: 320px;
    }

    .code-input {
      flex: 1;
      padding: 10px 14px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--bg-sunken);
      color: var(--fg);
      font-size: 16px;
      font-family: 'Geist Mono', monospace;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .code-input:focus {
      outline: none;
      border-color: var(--accent);
    }

    .code-go-btn {
      padding: 10px 20px;
      border: 1px solid var(--accent);
      border-radius: var(--radius-sm);
      background: var(--accent);
      color: white;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.12s;
    }

    .code-go-btn:hover {
      opacity: 0.85;
    }

    .code-quick-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .code-chip {
      padding: 5px 10px;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--bg-elev);
      color: var(--fg-muted);
      font-size: 12px;
      font-family: 'Geist Mono', monospace;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.12s, color 0.12s, border-color 0.12s;
    }

    .code-chip:hover {
      background: var(--bg-sunken);
      color: var(--fg);
      border-color: var(--border-strong);
    }

    @media (max-width: 640px) {
      .hero {
        padding: 60px 0 48px;
      }

      .hero h1 {
        font-size: 32px;
      }

      .hero-stats {
        flex-direction: column;
        gap: 20px;
      }

      .categories-grid,
      .symptom-grid {
        grid-template-columns: 1fr;
      }

      .code-input-wrap {
        max-width: 100%;
      }
    }
  </style>

  <script define:vars={{ codeMap: Object.fromEntries(codeGuides.map((g) => [g.code, g.slug])) }}>
    const input = document.getElementById('code-input');
    const goBtn = document.getElementById('code-go');
    const base = '/elsewhere/workshop/guides/';

    function navigate() {
      const code = input?.value.trim().toUpperCase().replace(/\s/g, '');
      if (!code) return;
      const slug = codeMap[code] ?? `fault-code-${code.toLowerCase()}`;
      window.location.href = base + slug;
    }

    goBtn?.addEventListener('click', navigate);
    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') navigate();
    });

    input?.addEventListener('input', () => {
      const pos = input.selectionStart;
      input.value = input.value.toUpperCase();
      input.setSelectionRange(pos, pos);
    });
  </script>
</BaseLayout>
