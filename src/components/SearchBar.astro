---
import Icon from './Icon.astro';

interface Props {
  placeholder?: string;
}
const { placeholder = 'Search guides, codes, parts…' } = Astro.props;
---

<div class="search-wrap">
  <span class="search-icon"><Icon name="search" size={16} /></span>
  <input
    type="search"
    class="input search-input"
    placeholder={placeholder}
    aria-label="Open search"
    readonly
    data-palette-trigger
  />
  <span class="kbd-hint mono"><span class="kbd">⌘K</span></span>
</div>

<style>
  .search-wrap {
    flex: 1;
    max-width: 520px;
    position: relative;
  }
  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--fg-soft);
    pointer-events: none;
  }
  .search-input {
    padding-left: 36px;
    padding-right: 56px;
    cursor: pointer;
  }
  .search-input::placeholder { color: var(--fg-soft); }
  .kbd-hint {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }
</style>

<script>
  // Placeholder behavior until the ⌘K palette is built (Phase 7).
  // Clicking the bar will eventually open the palette. For now, it focuses with a hint.
  const open = () => {
    window.dispatchEvent(new CustomEvent('elsewhere.palette.open'));
  };
  document.querySelectorAll<HTMLInputElement>('[data-palette-trigger]').forEach((el) => {
    el.addEventListener('click', open);
    el.addEventListener('focus', open);
  });
  window.addEventListener('keydown', (e) => {
    const isMod = e.metaKey || e.ctrlKey;
    if (isMod && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      open();
    }
  });
</script>
