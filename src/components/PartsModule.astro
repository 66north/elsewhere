---
/**
 * PartsModule — inline parts list with vendor links.
 * Renders a card with part rows: icon, name+OEM, vendor buttons, verdict pill.
 * Typically embedded in guide bodies after "Parts you'll need" section.
 */

import Icon from './Icon.astro';

interface Part {
  name: string;
  oem: string;
  spec: string;
  notes?: string;
  verify?: boolean;
}

interface Props {
  parts: Part[];
  showSponsored?: boolean;
}

const { parts = [], showSponsored = true } = Astro.props;

if (!parts || parts.length === 0) {
  // Silent — no parts module if no parts provided
}
---

{parts.length > 0 && (
  <div class="parts-module card">
    <div class="parts-header">
      <h3>Parts you'll need</h3>
      {showSponsored && <span class="sponsored-flag">Affiliate</span>}
    </div>

    <div class="parts-list">
      {parts.map((part) => (
        <div class="part-row">
          <div class="part-icon">
            <Icon name="box" size={16} />
          </div>
          <div class="part-info">
            <div class="part-name">{part.name}</div>
            <div class="part-meta mono">
              {part.oem && <span class="oem">{part.oem}</span>}
              {part.spec && <span class="spec">{part.spec}</span>}
            </div>
            {part.notes && <div class="part-notes">{part.notes}</div>}
          </div>
          <a href="#" class="btn btn-sm" title={`Buy ${part.name}`}>
            View
          </a>
        </div>
      ))}
    </div>

    <div class="parts-footer mono">
      <span>Some links are affiliate · supports the hub</span>
    </div>
  </div>
)}

<style>
  .parts-module {
    padding: 20px;
    margin: 24px 0;
  }
  .parts-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .parts-header h3 {
    margin: 0;
    font-size: 16px;
  }
  .sponsored-flag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-soft);
  }
  .sponsored-flag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .parts-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 12px;
  }
  .part-row {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 12px;
    align-items: flex-start;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
  }
  .part-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-sunken);
    border-radius: var(--radius-sm);
    color: var(--fg-muted);
    flex-shrink: 0;
  }
  .part-info {
    flex: 1;
  }
  .part-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 4px;
  }
  .part-meta {
    display: flex;
    gap: 8px;
    font-size: 11px;
    color: var(--fg-soft);
  }
  .part-meta .oem { font-weight: 500; }
  .part-meta .spec { opacity: 0.7; }
  .part-notes {
    margin-top: 6px;
    font-size: 12px;
    color: var(--fg-muted);
    line-height: 1.4;
  }

  .parts-footer {
    font-size: 11px;
    color: var(--fg-soft);
    text-align: center;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
</style>
