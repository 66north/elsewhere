---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getDifficultyLabel } from '../../../lib/guide';
import { path } from '../../../lib/site';

const guides = await getCollection('guides');

// Sort guides by title
const sortedGuides = guides.sort((a, b) =>
  (a.data.title || '').localeCompare(b.data.title || '')
);

// Group by category
const categories = Array.from(
  new Map(
    sortedGuides.map((guide) => [
      guide.data.category || 'other',
      (guides_by_cat) => guides_by_cat || [],
    ])
  ).entries()
);

const guidesById = new Map(sortedGuides.map((g) => [g.data.category || 'other', []]));
sortedGuides.forEach((guide) => {
  const cat = guide.data.category || 'other';
  if (!guidesById.has(cat)) {
    guidesById.set(cat, []);
  }
  guidesById.get(cat)!.push(guide);
});

const categoryList = Array.from(guidesById.entries()).sort(([a], [b]) => a.localeCompare(b));
---

<BaseLayout title="Guides" description="Workshop guides for Mitsubishi Pajero" section="workshop">
  <div class="guides-page">
    <header class="page-header">
      <h1>Workshop Guides</h1>
      <p class="eyebrow">{guides.length} comprehensive guides for Pajero repair and maintenance</p>
    </header>

    {categoryList.map(([category, categoryGuides]) => (
      <section class="category-section">
        <h2 class="category-title">{category.charAt(0).toUpperCase() + category.slice(1)}</h2>

        <div class="guides-grid">
          {categoryGuides.map((guide) => (
            <a href={path(`/workshop/guides/${guide.data.slug}`)} class="guide-card">
              <div class="guide-card-header">
                <h3>{guide.data.title}</h3>
                {guide.data.difficulty && (
                  <span class="difficulty-badge" data-difficulty={guide.data.difficulty}>
                    {getDifficultyLabel(guide.data.difficulty)}
                  </span>
                )}
              </div>

              <div class="guide-card-meta">
                {guide.data.gens && guide.data.gens.length > 0 && (
                  <span class="meta-tag">{guide.data.gens.join(', ')}</span>
                )}
                {guide.data.time_minutes && (
                  <span class="meta-tag">{guide.data.time_minutes}m</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <style>
    .guides-page {
      max-width: 1000px;
      margin: 0 auto;
      padding: 60px var(--spacing-page) 40px;
    }

    .page-header {
      margin-bottom: 48px;
      text-align: center;
    }

    .page-header h1 {
      font-size: 40px;
      margin-bottom: 8px;
      color: var(--fg);
    }

    .page-header .eyebrow {
      color: var(--fg-muted);
      font-size: 16px;
    }

    .category-section {
      margin-bottom: 48px;
    }

    .category-title {
      font-size: 18px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--fg-soft);
      margin-bottom: 20px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    .guides-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 16px;
    }

    .guide-card {
      display: block;
      padding: 20px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--bg-elev);
      color: inherit;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }

    .guide-card:hover {
      background: var(--bg-sunken);
      border-color: var(--border-strong);
    }

    .guide-card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .guide-card-header h3 {
      margin: 0;
      font-size: 16px;
      font-weight: 600;
      color: var(--fg);
      flex: 1;
    }

    .difficulty-badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 8px;
      border-radius: 3px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .difficulty-badge[data-difficulty='easy'] {
      background: oklch(0.85 0.12 150);
      color: oklch(0.35 0.1 150);
    }

    .difficulty-badge[data-difficulty='moderate'] {
      background: oklch(0.82 0.12 70);
      color: oklch(0.4 0.1 70);
    }

    .difficulty-badge[data-difficulty='hard'] {
      background: oklch(0.8 0.12 10);
      color: oklch(0.35 0.1 10);
    }

    .guide-card-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .meta-tag {
      display: inline-block;
      padding: 4px 8px;
      background: var(--bg-sunken);
      border-radius: 3px;
      font-size: 12px;
      color: var(--fg-muted);
    }

    @media (max-width: 640px) {
      .guides-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
