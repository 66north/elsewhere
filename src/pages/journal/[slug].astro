---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { path } from '../../lib/site';

interface Props {
  entry: any;
}

export async function getStaticPaths() {
  const entries = await getCollection('journal');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug, title, date, location, distance, duration_days } = entry.data;

const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Get all entries for navigation
const allEntries = await getCollection('journal');
const sorted = allEntries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const currentIndex = sorted.findIndex((e) => e.data.slug === slug);
const previousEntry = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextEntry = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

// BreadcrumbList schema
const fullEntryUrl = `https://66north.github.io/elsewhere/journal/${slug}`;
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://66north.github.io/elsewhere',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Journal',
      item: 'https://66north.github.io/elsewhere/journal',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: fullEntryUrl,
    },
  ],
};

// BlogPosting schema
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: entry.data.preview,
  datePublished: date,
  image: entry.data.image || 'https://66north.github.io/elsewhere/assets/pajero-build-reference.png',
  author: {
    '@type': 'Person',
    name: 'RD',
  },
};
---

<BaseLayout title={title} description={entry.data.preview} section="journal">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <article class="journal-post">
    <header class="post-header">
      <a href={path('/journal')} class="back-link">← Journal</a>
      <h1>{title}</h1>

      <div class="post-meta mono">
        <span>{formattedDate}</span>
        {location && <span>📍 {location}</span>}
        {distance && <span>{distance} km</span>}
        {duration_days && <span>{duration_days} {duration_days === 1 ? 'day' : 'days'}</span>}
      </div>
    </header>

    <div class="post-body">
      {entry.body ? (
        <div set:html={entry.body} />
      ) : (
        <p>{entry.data.preview}</p>
      )}
    </div>

    {(previousEntry || nextEntry) && (
      <nav class="post-nav">
        {previousEntry && (
          <a href={path(`/journal/${previousEntry.data.slug}`)} class="nav-link nav-prev">
            <span class="nav-label">← Previous</span>
            <span class="nav-title">{previousEntry.data.title}</span>
          </a>
        )}
        {nextEntry && (
          <a href={path(`/journal/${nextEntry.data.slug}`)} class="nav-link nav-next">
            <span class="nav-label">Next →</span>
            <span class="nav-title">{nextEntry.data.title}</span>
          </a>
        )}
      </nav>
    )}
  </article>

  <style>
    .journal-post {
      max-width: 760px;
      margin: 0 auto;
      padding: 60px var(--spacing-page) 40px;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 24px;
      font-size: 13px;
      color: var(--fg-muted);
      text-decoration: none;
      transition: color 0.15s;
    }

    .back-link:hover {
      color: var(--fg);
    }

    .post-header {
      margin-bottom: 40px;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--border);
    }

    .post-header h1 {
      margin: 16px 0 12px;
      font-size: 40px;
      line-height: 1.2;
      color: var(--fg);
    }

    .post-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      font-size: 13px;
      color: var(--fg-muted);
    }

    .post-body {
      font-size: 16px;
      line-height: 1.8;
      color: var(--fg);
      margin-bottom: 48px;
    }

    .post-body :global(h2) {
      margin: 32px 0 16px;
      font-size: 24px;
      font-weight: 600;
      color: var(--fg);
      scroll-margin-top: 100px;
    }

    .post-body :global(h3) {
      margin: 24px 0 12px;
      font-size: 18px;
      font-weight: 600;
      color: var(--fg);
      scroll-margin-top: 100px;
    }

    .post-body :global(p) {
      margin-bottom: 16px;
    }

    .post-body :global(ul),
    .post-body :global(ol) {
      margin: 16px 0 16px 24px;
    }

    .post-body :global(li) {
      margin-bottom: 8px;
    }

    .post-body :global(strong) {
      font-weight: 600;
      color: var(--fg);
    }

    .post-body :global(code) {
      padding: 2px 6px;
      background: var(--bg-sunken);
      border-radius: 3px;
      font-family: 'Geist Mono', monospace;
      font-size: 13px;
    }

    .post-body :global(blockquote) {
      padding-left: 16px;
      border-left: 3px solid var(--accent);
      margin: 16px 0;
      color: var(--fg-muted);
      font-style: italic;
    }

    .post-nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      padding: 24px;
      background: var(--bg-sunken);
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
    }

    .nav-link {
      display: flex;
      flex-direction: column;
      gap: 8px;
      color: inherit;
      text-decoration: none;
      transition: opacity 0.15s;
    }

    .nav-link:hover {
      opacity: 0.7;
    }

    .nav-link.nav-prev {
      align-items: flex-start;
    }

    .nav-link.nav-next {
      align-items: flex-end;
      text-align: right;
    }

    .nav-label {
      font-size: 12px;
      color: var(--fg-muted);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .nav-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--fg);
    }

    @media (max-width: 640px) {
      .journal-post {
        padding: 40px var(--spacing-page) 24px;
      }

      .post-header h1 {
        font-size: 28px;
      }

      .post-meta {
        gap: 12px;
        font-size: 12px;
      }

      .post-nav {
        grid-template-columns: 1fr;
      }

      .nav-link.nav-next {
        text-align: left;
        align-items: flex-start;
      }
    }
  </style>
</BaseLayout>
