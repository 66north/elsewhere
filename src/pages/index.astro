---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDifficultyLabel } from '../lib/guide';
import { path, site } from '../lib/site';

// Get some featured guides (maintenance + troubleshooting mix)
const guides = await getCollection('guides');
const featured = guides
  .filter(g => ['maintenance', 'troubleshoot'].includes(g.data.category || ''))
  .sort(() => Math.random() - 0.5)
  .slice(0, 4);

// Structured data schemas
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: 'https://66north.github.io/elsewhere',
  description: site.description,
  author: {
    '@type': 'Person',
    name: site.author,
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: 'https://66north.github.io/elsewhere',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://66north.github.io/elsewhere?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout section="home">
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <section class="hero container">
    <div class="hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Elsewhere · Reykjavík · 64.13°N · 21.94°W</span>
        <h1 class="hero-title">The road, the rig,<br />the workshop manual.</h1>
        <p class="hero-lede">
          A personal site about a 2009 Mitsubishi Pajero, the trips it takes, and the
          workshop manuals that keep it running. Long-form trip reports, an ongoing log of
          the build, and a hub of 100+ repair guides distilled from the factory service
          manual.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={path('/journal')}>Read latest entry</a>
          <a class="btn" href={path('/workshop')}>Browse workshop</a>
        </div>
        <dl class="hero-stats mono">
          <div><dt>Driven</dt><dd>248,310 km</dd></div>
          <div><dt>Trips</dt><dd>34</dd></div>
          <div><dt>Guides</dt><dd>112</dd></div>
        </dl>
      </div>
      <div class="hero-art">
        <img
          src={path('/assets/pajero-hero.jpg')}
          alt="The current Pajero build"
          class="hero-photo"
        />
        <span class="status-pill mono">Currently · Húsavík → Egilsstaðir</span>
      </div>
    </div>
  </section>

  <section class="container teaser">
    <div class="card teaser-card">
      <div class="teaser-copy">
        <span class="eyebrow">Workshop · 66°N</span>
        <h2>Or, if you came for the manuals.</h2>
        <p>
          A growing knowledge base of repair guides, fault codes, and a searchable archive
          of the factory service manual. Built first for me. Useful, hopefully, for you.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={path('/workshop')}>Open the workshop</a>
          <a class="btn" href={path('/workshop/archive')}>Factory manual archive</a>
        </div>
      </div>
      <dl class="teaser-stats mono">
        <div><dt>Guides</dt><dd>112</dd></div>
        <div><dt>Fault codes</dt><dd>1,240</dd></div>
        <div><dt>Manual pages</dt><dd>19,617</dd></div>
        <div><dt>Generations</dt><dd>3</dd></div>
      </dl>
    </div>
  </section>

  {featured.length > 0 ? (
    <section class="container featured-section">
      <div class="featured-header">
        <h2>A few popular guides</h2>
        <a href={path('/workshop/guides')} class="view-all">See all 112 →</a>
      </div>
      <div class="featured-grid">
        {featured.map((guide) => (
          <a href={path(`/workshop/guides/${guide.data.slug}`)} class="featured-card">
            <div class="featured-card-header">
              <h3>{guide.data.title}</h3>
              {guide.data.difficulty ? (
                <span class={`difficulty-badge difficulty-${guide.data.difficulty}`}>
                  {getDifficultyLabel(guide.data.difficulty)}
                </span>
              ) : null}
            </div>
            <div class="featured-meta mono">
              {guide.data.gens && guide.data.gens.length > 0 ? <span>{guide.data.gens.join(' · ')}</span> : null}
              {guide.data.time_minutes ? <span>{guide.data.time_minutes}m</span> : null}
            </div>
          </a>
        ))}
      </div>
    </section>
  ) : null}
</BaseLayout>

<style>
  .hero { padding-top: 72px; padding-bottom: 64px; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .hero-title {
    font-size: clamp(40px, 5.5vw, 64px);
    line-height: 1;
    letter-spacing: -0.025em;
    margin-top: 16px;
  }
  .hero-lede {
    margin-top: 20px;
    font-size: 19px;
    line-height: 1.55;
    color: var(--fg-muted);
    max-width: 56ch;
  }
  .hero-actions {
    display: flex;
    gap: 10px;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  .hero-stats {
    display: flex;
    gap: 28px;
    margin: 32px 0 0;
    padding: 0;
    color: var(--fg-soft);
    font-size: 12px;
  }
  .hero-stats div { display: flex; flex-direction: column; }
  .hero-stats dt { letter-spacing: 0.08em; text-transform: uppercase; font-size: 10px; }
  .hero-stats dd {
    margin: 4px 0 0;
    font-size: 18px;
    color: var(--fg);
    font-weight: 500;
  }

  .hero-art {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-sunken);
    border: 1px solid var(--border);
  }
  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .status-pill {
    position: absolute;
    right: 16px;
    bottom: 16px;
    padding: 6px 10px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 11px;
    color: var(--fg-muted);
  }

  .teaser { padding-top: 32px; }
  .teaser-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
    padding: 32px;
    align-items: center;
  }
  .teaser-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 0;
    padding: 24px;
    background: var(--bg-sunken);
    border-radius: var(--radius);
  }
  .teaser-stats div { display: flex; flex-direction: column; }
  .teaser-stats dt { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-soft); }
  .teaser-stats dd { margin: 4px 0 0; font-size: 22px; color: var(--fg); font-weight: 600; }

  .featured-section {
    padding: 64px 0;
    border-top: 1px solid var(--border);
  }

  .featured-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .featured-header h2 {
    font-size: 24px;
    font-weight: 600;
    margin: 0;
  }

  .view-all {
    font-size: 14px;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .view-all:hover {
    color: var(--fg);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
  }

  .featured-card {
    display: block;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-elev);
    color: inherit;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .featured-card:hover {
    background: var(--bg-sunken);
    border-color: var(--border-strong);
  }

  .featured-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 12px;
  }

  .featured-card-header h3 {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--fg);
    flex: 1;
  }

  .difficulty-badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    border-radius: 3px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .difficulty-easy {
    background: oklch(0.85 0.12 150);
    color: oklch(0.35 0.1 150);
  }

  .difficulty-moderate {
    background: oklch(0.82 0.12 70);
    color: oklch(0.4 0.1 70);
  }

  .difficulty-hard {
    background: oklch(0.8 0.12 10);
    color: oklch(0.35 0.1 10);
  }

  .featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 12px;
    color: var(--fg-muted);
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .teaser-card { grid-template-columns: 1fr; }
    .featured-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
