---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout section="journal" title="Journal" description="Trip reports from the road.">
  <section class="container page-stub">
    <span class="eyebrow">Journal</span>
    <h1>Trip reports & expedition logs</h1>
    <p class="lede">Long-form posts about the road. Coming soon — real journal entries with photos, route maps, and kit lists.</p>
  </section>
</BaseLayout>

<style>
  .page-stub { padding: 72px 0; }
  .lede { margin-top: 16px; font-size: 17px; color: var(--fg-muted); max-width: 60ch; }
</style>
