---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout section="build" title="The Build" description="Current spec sheet, parts log, and timeline of the 2009 Pajero NS.">
  <section class="container page-stub">
    <span class="eyebrow">The Build</span>
    <h1>Eleven thousand euros, three years, twenty-three changes.</h1>
    <p class="lede">Current spec, every part fitted, timeline of mods, and where to buy them. The build philosophy: durable, efficient, photogenic.</p>
  </section>
</BaseLayout>

<style>
  .page-stub { padding: 72px 0; }
  .lede { margin-top: 16px; font-size: 17px; color: var(--fg-muted); max-width: 60ch; }
</style>
