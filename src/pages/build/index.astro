---
import { path } from '../../lib/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout section="build" title="The Build" description="Current spec sheet, parts log, and timeline of the 2009 Pajero NS.">
  <div class="build-page">
    <header class="build-header">
      <span class="eyebrow">The Build</span>
      <h1>2009 Mitsubishi Pajero NS</h1>
      <p class="lede">
        Eleven thousand euros, three years, twenty-three modifications. Built for expedition reliability: durable, efficient, and capable of 10,000 km between services in remote terrain.
      </p>
    </header>

    <!-- Current Specs -->
    <section class="specs-section">
      <h2>Current Specification</h2>
      <div class="specs-grid">
        <div class="spec-card">
          <div class="spec-label">Generation</div>
          <div class="spec-value">NS (2006–2015)</div>
        </div>
        <div class="spec-card">
          <div class="spec-label">Engine</div>
          <div class="spec-value">4M40 2.5L Diesel</div>
          <div class="spec-detail">163 PS / 380 Nm</div>
        </div>
        <div class="spec-card">
          <div class="spec-label">Transmission</div>
          <div class="spec-value">5-speed Manual</div>
          <div class="spec-detail">Super Select 4WD</div>
        </div>
        <div class="spec-card">
          <div class="spec-label">Mileage</div>
          <div class="spec-value">248,310 km</div>
          <div class="spec-detail">Since May 2022</div>
        </div>
        <div class="spec-card">
          <div class="spec-label">Fuel Tank</div>
          <div class="spec-value">88 L</div>
          <div class="spec-detail">~1,100 km range (highway)</div>
        </div>
        <div class="spec-card">
          <div class="spec-label">Consumption</div>
          <div class="spec-value">7.8–8.2 L/100km</div>
          <div class="spec-detail">Highway; 9.5+ off-road</div>
        </div>
        <div class="spec-card">
          <div class="spec-label">Suspension</div>
          <div class="spec-value">Lifted 50mm</div>
          <div class="spec-detail">Ironman springs + custom shocks</div>
        </div>
        <div class="spec-card">
          <div class="spec-label">Tires</div>
          <div class="spec-value">BBS Bridgestone Dueler</div>
          <div class="spec-detail">265/65R17 A/T</div>
        </div>
      </div>
    </section>

    <!-- Build Timeline -->
    <section class="timeline-section">
      <h2>Build Timeline</h2>
      <div class="timeline">
        <div class="timeline-phase">
          <div class="phase-date mono">2024 Q1</div>
          <div class="phase-title">Foundation & Safety</div>
          <div class="phase-mods">
            <ul>
              <li>Engine service (oils, filters, belts)</li>
              <li>Brake fluid flush & new pads</li>
              <li>Suspension lift (Ironman + custom shocks)</li>
              <li>Steel bumpers (front + rear skid plate)</li>
              <li>LED light bar & fog lamps</li>
            </ul>
          </div>
        </div>

        <div class="timeline-phase">
          <div class="phase-date mono">2024 Q2</div>
          <div class="phase-title">Interior & Comfort</div>
          <div class="phase-mods">
            <ul>
              <li>ARB air locker (rear differential)</li>
              <li>Canvas canopy (tonneau cover)</li>
              <li>Bed lining (Upol Raptor)</li>
              <li>12V outlet & USB charging</li>
              <li>Improved ventilation & cabin insulation</li>
            </ul>
          </div>
        </div>

        <div class="timeline-phase">
          <div class="phase-date mono">2024 Q3</div>
          <div class="phase-title">Recovery & Protection</div>
          <div class="phase-mods">
            <ul>
              <li>Winch (Warn M8000, 3,600 kg)</li>
              <li>Hi-lift jack mount</li>
              <li>Recovery points (welded frame)</li>
              <li>Rock sliders (side protection)</li>
              <li>Engine skid plate reinforcement</li>
            </ul>
          </div>
        </div>

        <div class="timeline-phase">
          <div class="phase-date mono">2024 Q4</div>
          <div class="phase-title">Expedition Ready</div>
          <div class="phase-mods">
            <ul>
              <li>Roof rack (Rola Titan, 75 kg capacity)</li>
              <li>Dual batteries (auxiliary AGM)</li>
              <li>CTEK charger (DC-DC converter)</li>
              <li>Sat communicator (Iridium)</li>
              <li>Water tank (80L ARB auxiliary)</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Parts Categories -->
    <section class="parts-section">
      <h2>Parts by Category</h2>
      <div class="parts-grid">
        <div class="parts-category">
          <h3>Suspension & Drivetrain</h3>
          <ul>
            <li>Ironman 50mm coil springs</li>
            <li>Bilstein off-road shocks (4)</li>
            <li>ARB air locker (rear)</li>
            <li>Front diff guard</li>
            <li>BBS Bridgestone Dueler 265/65R17</li>
            <li>Diff oil cooler</li>
          </ul>
        </div>

        <div class="parts-category">
          <h3>Exterior Protection</h3>
          <ul>
            <li>Steel bull bar (front)</li>
            <li>Engine skid plate</li>
            <li>Transmission skid plate</li>
            <li>Rock sliders (side)</li>
            <li>Rear bumper with swing arm</li>
            <li>Canvas tonneau cover</li>
          </ul>
        </div>

        <div class="parts-category">
          <h3>Recovery & Traction</h3>
          <ul>
            <li>Warn M8000-s winch (3,600 kg)</li>
            <li>Braided synthetic rope</li>
            <li>Hi-lift jack (48")</li>
            <li>Snatch blocks (2x)</li>
            <li>Shackles & recovery points</li>
            <li>Maxtrax traction boards</li>
          </ul>
        </div>

        <div class="parts-category">
          <h3>Electrical & Power</h3>
          <ul>
            <li>Dual battery system (2x 200A AGM)</li>
            <li>CTEK D250S (DC-DC charger)</li>
            <li>Aux split relay</li>
            <li>Panorama fuse box</li>
            <li>LED light bar (60W)</li>
            <li>Fog lamps with relays</li>
          </ul>
        </div>

        <div class="parts-category">
          <h3>Storage & Carrying</h3>
          <ul>
            <li>Rola Titan roof rack (75 kg)</li>
            <li>Canvas cargo bag</li>
            <li>Bed lining (Upol Raptor)</li>
            <li>Storage boxes (under seats)</li>
            <li>ARB auxiliary water tank (80L)</li>
            <li>Fuel containers (2x 20L)</li>
          </ul>
        </div>

        <div class="parts-category">
          <h3>Interior & Comfort</h3>
          <ul>
            <li>Cabin insulation & ventilation</li>
            <li>12V dual outlet (front & rear)</li>
            <li>USB-C charging (3 ports)</li>
            <li>Heated seat covers</li>
            <li>Improved cabin lighting</li>
            <li>Sat communicator (Iridium)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Cost Breakdown -->
    <section class="cost-section">
      <h2>Investment Breakdown</h2>
      <div class="cost-breakdown">
        <div class="cost-row">
          <span class="cost-label">Vehicle (2009 Pajero NS)</span>
          <span class="cost-value">€3,200</span>
        </div>
        <div class="cost-row">
          <span class="cost-label">Engine overhaul & service</span>
          <span class="cost-value">€1,100</span>
        </div>
        <div class="cost-row">
          <span class="cost-label">Suspension & tires</span>
          <span class="cost-value">€2,300</span>
        </div>
        <div class="cost-row">
          <span class="cost-label">Recovery & protection</span>
          <span class="cost-value">€2,800</span>
        </div>
        <div class="cost-row">
          <span class="cost-label">Electrical & power</span>
          <span class="cost-value">€1,200</span>
        </div>
        <div class="cost-row">
          <span class="cost-label">Storage & auxiliary</span>
          <span class="cost-value">€600</span>
        </div>
        <div class="cost-row total">
          <span class="cost-label">Total Investment</span>
          <span class="cost-value">€11,200</span>
        </div>
      </div>
    </section>

    <!-- Build Philosophy -->
    <section class="philosophy-section">
      <h2>Build Philosophy</h2>
      <div class="philosophy-content">
        <p>
          <strong>Durability first.</strong> Every component is chosen for reliability in remote terrain, not aesthetics. The 4M40 diesel engine is known for longevity; suspension and recovery systems are military-spec where possible.
        </p>
        <p>
          <strong>Self-sufficiency.</strong> The build enables 10,000+ km expeditions without resupply. Dual batteries, water storage, recovery equipment, and navigation tools support autonomous travel.
        </p>
        <p>
          <strong>Efficiency matters.</strong> At 8 L/100km highway, 1,100 km range is achievable. The engine is carefully maintained to preserve fuel economy even in harsh conditions.
        </p>
        <p>
          <strong>Photogenic engineering.</strong> Function drives form, but the result is also visually coherent. The Pajero's clean lines, combined with practical mods, make for compelling expedition photography.
        </p>
        <p>
          <strong>Maintainability.</strong> All mods use standard parts and tools. In remote areas, the goal is to fix, not replace. OEM parts are specified where possible; aftermarket parts are chosen for spare-parts availability.
        </p>
      </div>
    </section>
  </div>

  <style>
    .build-page {
      max-width: 900px;
      margin: 0 auto;
      padding: 60px var(--spacing-page) 40px;
    }

    .build-header {
      margin-bottom: 60px;
    }

    .build-header h1 {
      font-size: 40px;
      margin: 12px 0 16px;
      color: var(--fg);
    }

    .lede {
      font-size: 17px;
      line-height: 1.6;
      color: var(--fg-muted);
      max-width: 70ch;
    }

    section {
      margin-bottom: 60px;
    }

    h2 {
      font-size: 28px;
      font-weight: 600;
      margin: 0 0 24px;
      color: var(--fg);
    }

    /* Specs Section */
    .specs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 16px;
    }

    .spec-card {
      padding: 16px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--bg-elev);
    }

    .spec-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--fg-soft);
      font-weight: 500;
      margin-bottom: 4px;
    }

    .spec-value {
      font-size: 16px;
      font-weight: 600;
      color: var(--fg);
    }

    .spec-detail {
      font-size: 12px;
      color: var(--fg-muted);
      margin-top: 4px;
    }

    /* Timeline Section */
    .timeline {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .timeline-phase {
      padding: 24px;
      border-left: 3px solid var(--accent);
      border-bottom: 1px solid var(--border);
      background: var(--bg-sunken);
    }

    .timeline-phase:last-child {
      border-bottom: none;
    }

    .phase-date {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--fg-soft);
      margin-bottom: 8px;
    }

    .phase-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--fg);
      margin-bottom: 12px;
    }

    .phase-mods {
      font-size: 14px;
    }

    .phase-mods ul {
      margin: 0;
      padding-left: 20px;
      list-style: disc;
    }

    .phase-mods li {
      margin: 6px 0;
      color: var(--fg-muted);
    }

    /* Parts Section */
    .parts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }

    .parts-category {
      padding: 20px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--bg-elev);
    }

    .parts-category h3 {
      margin: 0 0 12px;
      font-size: 16px;
      font-weight: 600;
      color: var(--fg);
    }

    .parts-category ul {
      margin: 0;
      padding-left: 20px;
      list-style: disc;
      font-size: 13px;
    }

    .parts-category li {
      margin: 6px 0;
      color: var(--fg-muted);
    }

    /* Cost Section */
    .cost-breakdown {
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      overflow: hidden;
    }

    .cost-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      font-size: 14px;
    }

    .cost-row:last-child {
      border-bottom: none;
    }

    .cost-row.total {
      background: var(--bg-sunken);
      font-weight: 600;
      font-size: 16px;
    }

    .cost-label {
      color: var(--fg);
    }

    .cost-value {
      color: var(--accent);
      font-weight: 600;
      font-family: 'Geist Mono', monospace;
    }

    /* Philosophy Section */
    .philosophy-content {
      font-size: 15px;
      line-height: 1.8;
      color: var(--fg-muted);
    }

    .philosophy-content p {
      margin: 0 0 16px;
    }

    .philosophy-content p:last-child {
      margin-bottom: 0;
    }

    .philosophy-content strong {
      color: var(--fg);
      font-weight: 600;
    }

    @media (max-width: 640px) {
      .build-page {
        padding: 40px var(--spacing-page) 24px;
      }

      .build-header h1 {
        font-size: 32px;
      }

      .specs-grid {
        grid-template-columns: 1fr;
      }

      .parts-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
