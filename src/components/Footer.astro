---
import { site, path } from '../lib/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col footer-brand">
      <a class="footer-logo" href={path('/')}>
        <img src={path('/assets/elsewhere-logo.png')} alt="" width="28" height="28" />
        <span class="wordmark">{site.name}</span>
      </a>
      <p class="mono footer-tagline">{site.tagline}</p>
    </div>

    <div class="footer-col">
      <span class="eyebrow">The site</span>
      <ul>
        <li><a href={path('/journal')}>Journal</a></li>
        <li><a href={path('/build')}>The Build</a></li>
        <li><a href={path('/workshop')}>Workshop</a></li>
        <li><a href={path('/about')}>About</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <span class="eyebrow">Elsewhere</span>
      <ul>
        <li><a href="https://github.com/66north" rel="me">GitHub</a></li>
        <li><a href={path('/about/affiliate-policy')}>Affiliate policy</a></li>
        <li><a href={path('/colophon')}>Colophon</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <span class="eyebrow">Newsletter</span>
      <p class="footer-blurb">Trip reports and workshop notes, sent occasionally. No spam.</p>
      <form class="footer-newsletter" aria-label="Newsletter signup">
        <input type="email" class="input" placeholder="you@email" disabled />
        <button class="btn btn-sm" disabled type="button">Soon</button>
      </form>
    </div>
  </div>

  <div class="footer-bottom container">
    <span class="mono">© {year} {site.name}</span>
    <span class="mono">v0.1.0</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    border-top: 1px solid var(--border);
    padding-top: 48px;
    padding-bottom: 24px;
    color: var(--fg-muted);
    font-size: 13px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.4fr;
    gap: 40px;
  }
  .footer-col ul {
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .footer-col a:hover { color: var(--fg); }

  .footer-brand .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--fg);
    font-weight: 600;
  }
  .footer-tagline { margin-top: 8px; font-size: 11px; color: var(--fg-soft); }
  .footer-blurb { margin-top: 10px; font-size: 12px; }

  .footer-newsletter {
    display: flex;
    gap: 6px;
    margin-top: 10px;
  }
  .footer-newsletter .input { flex: 1; }

  .footer-bottom {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    color: var(--fg-soft);
    font-size: 11px;
  }

  @media (max-width: 900px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>
