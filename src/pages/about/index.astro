---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout section="about" title="About" description="About Elsewhere, the site, and the author.">
  <section class="container page-stub">
    <span class="eyebrow">About</span>
    <h1>About this place</h1>
    <p class="lede">
      Contact, site colophon, affiliate disclosure, and the story behind the workshop hub. Coming soon.
    </p>
  </section>
</BaseLayout>

<style>
  .page-stub { padding: 72px 0; }
  .lede { margin-top: 16px; font-size: 17px; color: var(--fg-muted); max-width: 60ch; }
</style>
