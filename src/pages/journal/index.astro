---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { path } from '../../lib/site';

const entries = await getCollection('journal');
const sorted = entries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout section="journal" title="Journal" description="Trip reports from the road.">
  <div class="journal-page">
    <header class="journal-header">
      <span class="eyebrow">Journal</span>
      <h1>Trip reports & expedition logs</h1>
      <p class="lede">Long-form posts about the road, off-road exploration, and the Pajero's adventures across Iceland.</p>
    </header>

    <div class="journal-list">
      {sorted.map((entry) => {
        const date = new Date(entry.data.date);
        const month = date.toLocaleDateString('en-US', { month: 'short' });
        const day = date.getDate();
        const year = date.getFullYear();

        return (
          <article class="journal-entry">
            <div class="entry-date mono">
              <div class="date-month">{month}</div>
              <div class="date-day">{day}</div>
            </div>

            <div class="entry-content">
              <a href={path(`/journal/${entry.data.slug}`)} class="entry-title-link">
                <h2 class="entry-title">{entry.data.title}</h2>
              </a>

              <div class="entry-meta mono">
                <span class="location">📍 {entry.data.location}</span>
                {entry.data.distance && <span class="distance">{entry.data.distance} km</span>}
                {entry.data.duration_days && <span class="duration">{entry.data.duration_days} days</span>}
              </div>

              <p class="entry-preview">{entry.data.preview}</p>

              <a href={path(`/journal/${entry.data.slug}`)} class="read-more">
                Read story →
              </a>
            </div>
          </article>
        );
      })}
    </div>

    {sorted.length === 0 && (
      <div class="empty-state">
        <p>No journal entries yet. Check back soon for trip reports from the road.</p>
      </div>
    )}
  </div>

  <style>
    .journal-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 60px var(--spacing-page) 40px;
    }

    .journal-header {
      margin-bottom: 48px;
    }

    .journal-header h1 {
      font-size: 40px;
      margin: 12px 0 16px;
      color: var(--fg);
    }

    .lede {
      font-size: 17px;
      line-height: 1.6;
      color: var(--fg-muted);
      max-width: 60ch;
    }

    .journal-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .journal-entry {
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 24px;
      padding: 24px 0;
      border-bottom: 1px solid var(--border);
    }

    .journal-entry:last-child {
      border-bottom: none;
    }

    .entry-date {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding-top: 4px;
      font-size: 12px;
      color: var(--fg-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .date-month {
      font-weight: 600;
      color: var(--fg);
    }

    .date-day {
      font-size: 18px;
      font-weight: 700;
      color: var(--fg);
      margin: 4px 0;
    }

    .entry-content {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .entry-title-link {
      text-decoration: none;
      color: inherit;
    }

    .entry-title {
      margin: 0;
      font-size: 22px;
      font-weight: 600;
      color: var(--fg);
      transition: color 0.15s;
    }

    .entry-title-link:hover .entry-title {
      color: var(--accent);
    }

    .entry-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      font-size: 12px;
      color: var(--fg-muted);
    }

    .entry-preview {
      margin: 8px 0 0;
      font-size: 15px;
      line-height: 1.6;
      color: var(--fg-muted);
    }

    .read-more {
      align-self: flex-start;
      margin-top: 8px;
      font-size: 13px;
      color: var(--fg);
      text-decoration: none;
      font-weight: 500;
      transition: opacity 0.15s;
    }

    .read-more:hover {
      opacity: 0.7;
    }

    .empty-state {
      padding: 60px 20px;
      text-align: center;
      color: var(--fg-muted);
    }

    @media (max-width: 640px) {
      .journal-page {
        padding: 40px var(--spacing-page) 24px;
      }

      .journal-header h1 {
        font-size: 32px;
      }

      .journal-entry {
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .entry-date {
        flex-direction: row;
        gap: 12px;
        justify-content: flex-start;
      }
    }
  </style>
</BaseLayout>
